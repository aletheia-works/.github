# Copy this file to terraform.tfvars and fill in the values.
# terraform.tfvars itself is gitignored and must not be committed.
#
# Local usage:
#   cp terraform.tfvars.example terraform.tfvars
#   # edit terraform.tfvars
#   export GITHUB_TOKEN=github_pat_xxxxxxxxxxxx
#   tofu init
#   tofu plan
#   tofu apply
#
# In GitHub Actions, tfvars are not used — values are injected via
# environment variables (TF_VAR_billing_email) and workflow inputs.

github_owner   = "aletheia-works"
billing_email  = "jambalaya.pyoncafe@gmail.com"

# Defaults are usually fine. Override only when needed:
# org_description = "Universal bug reproduction in the AI era"
# org_owners      = ["JamBalaya56562"]
